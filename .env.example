# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://localhost:27017/astrologic_lms

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Email (SMTP - e.g. Zoho Mail / Amazon SES / Brevo)
SMTP_HOST=smtp.zoho.in
SMTP_PORT=465
SMTP_USER=notifications@icasastrologic.org
SMTP_PASS=your_smtp_password
SMTP_FROM="ICAS AstroLogic Chapter <notifications@icasastrologic.org>"

# File uploads
MAX_UPLOAD_SIZE_MB=10

# Admin bootstrap (used only by seed script)
SEED_ADMIN_EMAIL=admin@icasastrologic.org
SEED_ADMIN_PASSWORD=ChangeMe@123
