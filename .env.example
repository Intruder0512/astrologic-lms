# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database (MongoDB Atlas)
# IMPORTANT: your Atlas connection string needs a database name before the "?" -
# e.g. .../astrologic_lms?appName=Cluster0 - otherwise Mongoose defaults to "test"
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/astrologic_lms?appName=Cluster0

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Microsoft Teams live classes (Phase 2) - see src/services/msGraph.js for
# full Azure AD setup steps. Not set = live classes still work, just without
# an auto-created Teams link (instructor can add one manually).
MS_TENANT_ID=your_azure_ad_tenant_id
MS_CLIENT_ID=your_azure_app_client_id
MS_CLIENT_SECRET=your_azure_app_client_secret

# Email (SMTP - e.g. Zoho Mail / Amazon SES / Brevo)
SMTP_HOST=smtp.zoho.in
SMTP_PORT=465
SMTP_USER=notifications@icasastrologic.org
SMTP_PASS=your_smtp_password
SMTP_FROM="ICAS Lucknow-III <notifications@icasastrologic.org>"

# File uploads
MAX_UPLOAD_SIZE_MB=10

# Admin bootstrap (used only by seed script)
SEED_ADMIN_EMAIL=admin@icasastrologic.org
SEED_ADMIN_PASSWORD=ChangeMe@123
